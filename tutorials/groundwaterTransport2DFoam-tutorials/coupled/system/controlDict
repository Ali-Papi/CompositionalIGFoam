FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     groundwaterTransport2DFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         4.73364e+9;

deltaT          1;

writeControl    adjustableRunTime;

writeInterval   4.73364e+09;

purgeWrite      0;

writeFormat     ascii;

writePrecision  10;

writeCompression off;

timeFormat      general;

timePrecision   10;

adjustTimeStep  yes;

runTimeModifiable yes;

truncationError_hwater 0.001;
truncationError_C 1.0;
maxDeltaT	3.15576e+07;

outputEventFile "output_dates.evt";

CSVoutput       true;

eventTimeTracking false;

// ************************************************************************* //
