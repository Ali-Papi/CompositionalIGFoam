FoamFile
{
  version     2.0;
  format      ascii;
  class       dictionary;
  location    "constant";
  object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

eps eps [0 0 0 0 0 0 0]	0.27;
Dm Dm [0 2 -1 0 0 0 0] 1e-9;

porousTransport
{
    Kd Kd [-1 3 0 0 0 0 0] 0.0001;
    rs rs [1 -3 0 0 0 0 0] 2840;
    epsTotal epsTotal [0 0 0 0 0 0 0] 0.30;
    lambda lambda [0 0 -1 0 0 0 0 ] 1e-12;
}

dispersionModel alphaDispersion;

alphaDispersionCoeffs
{
    tau tau [0 0 0 0 0 0 0] 1;
    alphaL alphaL [0 1 0 0 0 0 0] 100;
    alphaT alphaT [0 1 0 0 0 0 0] 20;
}

sourceEventFileTracer variable_inflow.evt;

