FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         no;
    ddt(theta)      Euler;
    ddt(h)          Euler;
    ddt(theta,C)    backward;
    ddt(C)          backward;   
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         Gauss linear;
    div(phi,C)      Gauss linear;
}

laplacianSchemes
{
    default         Gauss linear corrected;;
}

interpolationSchemes
{
    default	    linear;
    K		    linear;
    pc   	    linear;
    krtheta         linear;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    default         no;
}

