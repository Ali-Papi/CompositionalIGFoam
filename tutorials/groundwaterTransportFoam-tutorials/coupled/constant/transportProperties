FoamFile
{
  version     2.0;
  format      ascii;
  class       dictionary;
  location    "constant";
  object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

Ss Ss [0 -1 0 0 0 0 0] 0.001;

phase.theta
{
    rho	rho [1 -3 0 0 0 0 0] 1000;
    mu	mu [1 -1 -1 0 0 0 0] 1e-3;
}

relativePermeabilityModel  VanGenuchten;

capillarityModel	VanGenuchten;

VanGenuchtenCoeffs
{
    thetamin  0.01485;
    thetamax  0.243;
    m	0.300699;
    alpha 13.0;
}

// transport properties
eps eps [0 0 0 0 0 0 0] 0.27;
Dm Dm [0 2 -1 0 0 0 0] 1e-9;

porousTransport
{
    Kd Kd [-1 3 0 0 0 0 0] 0;
    rs rs [1 -3 0 0 0 0 0] 2840;
    epsTotal epsTotal [0 0 0 0 0 0 0] 0.30;
    lambda lambda [0 0 -1 0 0 0 0 ] 1e-9;
}

dispersionModel alphaDispersion;

alphaDispersionCoeffs
{
    tau tau [0 0 0 0 0 0 0] 1;
    alphaL alphaL [0 1 0 0 0 0 0] 1.0;
    alphaT alphaT [0 1 0 0 0 0 0] 0.20;
}

// event files
sourceEventFileTracer "debit_entrant.evt";
sourceEventFileWater "eau_entrant.evt";

